{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "ES2023",

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "jest"
    ],

    "strictNullChecks": true,
    "incremental": true,
    "outDir": "./dist"
  }
}